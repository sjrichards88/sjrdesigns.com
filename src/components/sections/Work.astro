---
import Button from '@/components/Button.astro';
import WorkProjectItem from '@/components/WorkProjectItem.astro';
import framelessImg from '@/assets/images/frameless.jpg'
import tasteImg from '@/assets/images/taste.jpg'
import thewalkImg from '@/assets/images/thewalk.jpg'
import holidayOnIceImg from '@/assets/images/holidayonice.com.png'
import moulinRougeImg from '@/assets/images/moulinrougemusical.co.uk.png'
import bowsImg from '@/assets/images/bows.jpg'
import ratefeedImg from '@/assets/images/ratefeed.co.uk.png'
import wsmImg from '@/assets/images/wsm.jpg'
import womensScottishImg from '@/assets/images/womensscottish.jpg'
import pncImg from '@/assets/images/pnc.jpg'
import justDanceLiveImg from '@/assets/images/just-dance-live.jpg'
import multipleCalcsImg from '@/assets/images/multiplecalcs.com.png'

const MOBILE_VISIBLE_COUNT = 5;

const featuredProjects = [
	{ title: "Frameless", subtitle: "Immersive Art Experience • developed at Dewynters", image: framelessImg, url: "https://frameless.com/", delay: "work-delay-100" },
	{ title: "Taste Festival", subtitle: "Culinary Celebration • developed at Dewynters", image: tasteImg, url: "https://london.tastefestivals.com/", delay: "work-delay-200" },
	{ title: "Walk With Amal", subtitle: "Interactive Journey • developed at Dewynters", image: thewalkImg, url: "https://walkwithamal.org/", delay: "work-delay-250" },
	{ title: "Holiday On Ice", subtitle: "International ice show • developed at Dewynters", image: holidayOnIceImg, url: "https://holidayonice.com/", delay: "work-delay-275" },
	{ title: "Moulin Rouge Musical", subtitle: "West End musical • developed at Dewynters", image: moulinRougeImg, url: "https://moulinrougemusical.co.uk/", delay: "work-delay-290" },
	{ title: "Bouquets & Bows", subtitle: "Luxury wedding planning • independent project", image: bowsImg, url: "https://bouquetsandbows.com/", delay: "work-delay-300" },
	{ title: "RateFeed", subtitle: "Trades price comparison tool • independent project", image: ratefeedImg, url: "https://ratefeed.co.uk/", delay: "work-delay-325" },
	{ title: "The World's Strongest Man", subtitle: "Strength Athletics Championship • developed at Dewynters", image: wsmImg, url: "https://www.theworldsstrongestman.com/", delay: "work-delay-350" },
];

const moreProjects = [
	{ title: "Women's Scottish Open", subtitle: "Golf Championship", image: womensScottishImg, url: "https://www.womensscottish.com/", delay: "work-delay-450" },
	{ title: "PNC Championship", subtitle: "Golf Tournament", image: pncImg, url: "https://www.pncchampionship.com/", delay: "work-delay-550" },
	{ title: "Just Dance Live", subtitle: "Interactive Entertainment", image: justDanceLiveImg, url: "https://justdancelive.com/", delay: "work-delay-650" },
	{ title: "Multiple Calcs", subtitle: "Online calculator tools", image: multipleCalcsImg, url: "https://multiplecalcs.com/", delay: "work-delay-700" },
];

const mobileVisibleProjects = featuredProjects.slice(0, MOBILE_VISIBLE_COUNT);
const mobileMoreProjects = [...featuredProjects.slice(MOBILE_VISIBLE_COUNT), ...moreProjects];
---

<section id="work" class="relative py-24 bg-gradient-to-br from-slate-50 via-white to-teal-50 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.02] bg-dot-pattern-work"></div>
  <div class="absolute top-20 right-20 w-72 h-72 bg-gradient-to-br from-teal-300/15 to-emerald-300/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-20 left-20 w-96 h-96 bg-gradient-to-br from-cyan-300/15 to-blue-300/10 rounded-full blur-3xl animate-pulse animate-delay-2s"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-20 animate-item">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-teal-100 to-emerald-100 border border-teal-200/50 rounded-full mb-6 shadow-sm">
        <div class="w-2 h-2 bg-gradient-to-r from-teal-500 to-emerald-500 rounded-full animate-pulse"></div>
        <span class="bg-gradient-to-r from-teal-600 to-emerald-600 bg-clip-text text-transparent text-sm font-medium">Portfolio</span>
      </div>
      <h2 class="font-heading font-bold text-neutral-900 mb-6" style="font-size: clamp(2rem, 6vw, 4rem);">
        Featured
        <span class="bg-gradient-to-r from-cyan-500 via-blue-500 to-teal-500 bg-clip-text text-transparent">Work</span>
      </h2>
      <p class="text-neutral-600 max-w-3xl mx-auto leading-relaxed text-work-subtitle text-lg">
        <span class="lg:hidden">Tap a project to visit the live site.</span>
        <span class="hidden lg:inline">From world-renowned entertainment venues to major sporting championships. Hover over projects to explore them.</span>
      </p>
    </div>

    <div class="max-w-5xl mx-auto">
      <!-- Mobile: first 5 projects -->
      <div class="lg:hidden space-y-4 mb-4">
        {mobileVisibleProjects.map((project) => (
          <WorkProjectItem {...project} />
        ))}
      </div>

      <!-- Desktop: all featured projects -->
      <div class="desktop-project-list hidden lg:block space-y-4 mb-16">
        {featuredProjects.map((project) => (
          <WorkProjectItem {...project} />
        ))}
      </div>

      <!-- Mobile: collapsible more projects -->
      {mobileMoreProjects.length > 0 && (
        <details id="mobile-more-projects" class="work-more-details lg:hidden mb-12 animate-item work-delay-400">
          <summary class="work-more-summary flex items-center justify-between gap-3 py-3 px-4 bg-white/70 backdrop-blur-sm border border-neutral-200/50 rounded-2xl cursor-pointer list-none select-none">
            <span class="text-lg font-heading font-semibold text-neutral-800">More Projects</span>
            <span class="flex items-center gap-2 text-sm text-neutral-500">
              <span>{mobileMoreProjects.length} more</span>
              <svg class="work-more-chevron w-5 h-5 text-teal-600 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="space-y-4 mt-4">
            {mobileMoreProjects.map((project) => (
              <WorkProjectItem {...project} />
            ))}
          </div>
        </details>
      )}

      <!-- Desktop: more projects grid -->
      <div class="desktop-project-list hidden lg:block text-center mb-12 animate-item work-delay-400">
        <h3 class="text-xl font-heading font-semibold text-neutral-700 mb-8">More Projects</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {moreProjects.map((project) => (
            <WorkProjectItem {...project} compact />
          ))}
        </div>
      </div>
    </div>

    <div class="text-center mt-20 animate-item work-delay-700">
      <div class="inline-block p-8 lg:p-12 bg-gradient-to-br from-white via-teal-50/30 to-emerald-50/30 border border-teal-200/40 rounded-3xl shadow-lg backdrop-blur-sm">
        <h3 class="font-heading font-bold text-neutral-900 mb-4 text-work-cta-title">
          Ready to Join This Portfolio?
        </h3>
        <p class="text-neutral-600 mb-6 max-w-md mx-auto text-work-cta-subtitle">
          Let's create something exceptional together that showcases your brand's unique story.
        </p>
        <Button href="#contact" variant="primary" size="md" icon="arrow">
          Start Your Project
        </Button>
      </div>
    </div>
  </div>
</section>

<div id="mouseImagePreview" class="hidden lg:block fixed pointer-events-none z-[200] opacity-0 transition-opacity duration-300" aria-hidden="true">
  <img id="previewImage" src="" alt="" loading="lazy" class="w-80 h-48 object-cover rounded-2xl border border-neutral-200/80">
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const projectItems = document.querySelectorAll('#work .desktop-project-list .project-item') as NodeListOf<HTMLElement>;
    const mousePreview = document.getElementById('mouseImagePreview') as HTMLElement | null;
    const previewImage = document.getElementById('previewImage') as HTMLImageElement | null;
    const mobileMoreDetails = document.getElementById('mobile-more-projects') as HTMLDetailsElement | null;
    let isHovering = false;
    let currentItem: HTMLElement | null = null;

    function isDesktopHover() {
      return window.matchMedia('(min-width: 1024px)').matches;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const element = entry.target as HTMLElement;
          element.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    function observeWorkItems(root: ParentNode = document) {
      root.querySelectorAll('#work .animate-item').forEach(item => {
        if (!item.classList.contains('visible')) {
          observer.observe(item);
        }
      });
    }

    observeWorkItems();

    mobileMoreDetails?.addEventListener('toggle', () => {
      if (mobileMoreDetails.open) {
        mobileMoreDetails.querySelectorAll('.animate-item').forEach(item => {
          item.classList.add('visible');
        });
      }
    });

    function updateMousePreview(e: MouseEvent) {
      if (!isHovering || !mousePreview || !previewImage) return;
      
      const mouseX = e.clientX;
      const mouseY = e.clientY;
      const windowWidth = window.innerWidth;
      const windowHeight = window.innerHeight;
      const previewWidth = 320;
      const previewHeight = 192;
      
      let x = mouseX + 20;
      let y = mouseY - previewHeight / 2;
      
      if (x + previewWidth > windowWidth) {
        x = mouseX - previewWidth - 20;
      }
      if (y < 20) {
        y = 20;
      }
      if (y + previewHeight > windowHeight - 20) {
        y = windowHeight - previewHeight - 20;
      }
      
      mousePreview.style.left = x + 'px';
      mousePreview.style.top = y + 'px';
    }

    projectItems.forEach(item => {
      const imageUrl = item.dataset.image || '';
      const projectUrl = item.dataset.url || '';

      item.addEventListener('mouseenter', function(e: MouseEvent) {
        if (!isDesktopHover() || !mousePreview || !previewImage) return;
        isHovering = true;
        currentItem = item;
        previewImage.src = imageUrl;
        mousePreview.style.opacity = '1';
        updateMousePreview(e);
      });

      item.addEventListener('mousemove', function(e: MouseEvent) {
        if (currentItem === item && isDesktopHover()) {
          updateMousePreview(e);
        }
      });

      item.addEventListener('mouseleave', function() {
        if (currentItem === item) {
          isHovering = false;
          currentItem = null;
          if (mousePreview) mousePreview.style.opacity = '0';
        }
      });
    });

    document.querySelectorAll('#work .project-item').forEach(item => {
      const projectUrl = (item as HTMLElement).dataset.url || '';

      item.addEventListener('click', function(e: MouseEvent) {
        if (projectUrl && !(e.target as Element).closest('summary')) {
          window.open(projectUrl, '_blank', 'noopener,noreferrer');
        }
      });
    });

    document.addEventListener('mousemove', function(e: MouseEvent) {
      if (isHovering && currentItem && isDesktopHover()) {
        updateMousePreview(e);
      }
    });

    document.addEventListener('mouseleave', function() {
      isHovering = false;
      currentItem = null;
      if (mousePreview) mousePreview.style.opacity = '0';
    });
  });
</script>

<style>
  .animate-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  
  .animate-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .work-more-summary::-webkit-details-marker {
    display: none;
  }

  .work-more-details[open] .work-more-chevron {
    transform: rotate(180deg);
  }

  .work-more-details[open] .work-more-summary {
    background-color: rgb(255 255 255 / 0.95);
    border-color: rgb(20 184 166 / 0.25);
  }

  #mouseImagePreview {
    transition: opacity 0.3s ease, transform 0.1s ease;
    will-change: transform;
  }

  #mouseImagePreview img {
    transition: transform 0.3s ease;
  }

  @media (min-width: 1024px) {
    .project-item:hover {
      transform: translateY(-2px);
    }
  }

  .project-item .group-hover\:translate-x-1:hover {
    transform: translateX(4px);
  }
</style>
