---
import BrandIcon from "@/components/BrandIcon.astro";
import {
	siClaude,
	siStackblitz,
	siV0,
	siWebflow,
	siWordpress,
} from "simple-icons";

const aiTools = [
	{
		name: "ChatGPT",
		logoSrc: "/brand/openai.svg",
		color: "from-emerald-500/20 to-teal-500/10",
		border: "border-emerald-500/30",
		iconBg: "bg-white ring-1 ring-black/10",
	},
	{
		name: "Claude",
		icon: siClaude,
		color: "from-orange-500/20 to-amber-500/10",
		border: "border-orange-500/30",
	},
	{
		name: "v0",
		icon: siV0,
		color: "from-neutral-500/20 to-neutral-400/10",
		border: "border-neutral-400/30",
		iconBg: "bg-white ring-1 ring-black/10",
	},
	{
		name: "Bolt",
		icon: siStackblitz,
		color: "from-blue-500/20 to-cyan-500/10",
		border: "border-blue-500/30",
	},
	{
		name: "Lovable",
		logoSrc: "/brand/lovable.svg",
		color: "from-pink-500/20 to-rose-500/10",
		border: "border-pink-500/30",
	},
	{
		name: "Webflow",
		icon: siWebflow,
		color: "from-indigo-500/20 to-violet-500/10",
		border: "border-indigo-500/30",
	},
];
---

<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto" aria-labelledby="ai-tools-heading">
	<h2 id="ai-tools-heading" class="text-2xl sm:text-3xl font-bold text-white mb-3 text-center">Which AI tools does this work with?</h2>
	<p class="text-neutral-400 text-center text-sm sm:text-base mb-10 max-w-3xl mx-auto leading-relaxed">
		Valid HTML and CSS from any of these - exported, zipped, or in a repo - can flow through to a production WordPress theme.
	</p>

	<div class="funnel-panel relative overflow-hidden rounded-3xl border border-white/10 bg-white/[0.03] p-6 sm:p-8 lg:p-10">
		<div class="absolute inset-0 opacity-40 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgb(255 255 255 / 0.06) 1px, transparent 0); background-size: 28px 28px;"></div>

		<!-- Desktop: horizontal funnel -->
		<div class="hidden lg:grid lg:grid-cols-[1.1fr_auto_0.75fr_auto_0.85fr] lg:items-center lg:gap-3 relative z-10">
			<div class="space-y-3">
				<p class="text-xs font-semibold uppercase tracking-wider text-violet-300/80 mb-4">AI &amp; design tools</p>
				<div class="grid grid-cols-2 gap-2.5">
					{aiTools.map((tool) => (
						<div class={`flex items-center gap-2.5 rounded-xl border bg-gradient-to-br px-3 py-2.5 ${tool.color} ${tool.border}`}>
							<span class={`flex h-8 w-8 shrink-0 items-center justify-center rounded-lg p-1.5 ${tool.iconBg ?? "bg-black/30"}`}>
								<BrandIcon icon={tool.icon} src={tool.logoSrc} label={tool.name} class="h-full w-full" />
							</span>
							<span class="text-sm font-medium text-white">{tool.name}</span>
						</div>
					))}
				</div>
			</div>

			<div class="funnel-connector funnel-connector--horizontal w-16 xl:w-24" aria-hidden="true">
				<div class="funnel-connector__track"></div>
				<span class="funnel-dot funnel-dot--1"></span>
				<span class="funnel-dot funnel-dot--2"></span>
				<span class="funnel-dot funnel-dot--3"></span>
				<svg class="funnel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</div>

			<div class="rounded-2xl border border-amber-500/25 bg-gradient-to-br from-amber-500/10 to-orange-500/5 p-5 text-center">
				<div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500/20 text-amber-300">
					<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
					</svg>
				</div>
				<p class="text-sm font-semibold text-white">HTML + CSS</p>
				<p class="text-xs text-neutral-400 mt-1">Static export</p>
			</div>

			<div class="funnel-connector funnel-connector--horizontal w-16 xl:w-24" aria-hidden="true">
				<div class="funnel-connector__track"></div>
				<span class="funnel-dot funnel-dot--1"></span>
				<span class="funnel-dot funnel-dot--2"></span>
				<span class="funnel-dot funnel-dot--3"></span>
				<svg class="funnel-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
				</svg>
			</div>

			<div class="rounded-2xl border border-blue-500/35 bg-gradient-to-br from-blue-500/15 to-violet-500/10 p-5 text-center funnel-destination">
				<div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-xl bg-white p-2 ring-2 ring-blue-400/30">
					<BrandIcon icon={siWordpress} label="WordPress" class="h-full w-full" fill="#000000" />
				</div>
				<p class="text-sm font-semibold text-white">WordPress theme</p>
				<p class="text-xs text-blue-200/80 mt-1">Editable · Ownable</p>
			</div>
		</div>

		<!-- Mobile: vertical funnel -->
		<div class="lg:hidden relative z-10 space-y-2">
			<p class="text-xs font-semibold uppercase tracking-wider text-violet-300/80 text-center mb-4">AI tools → WordPress</p>
			<div class="flex flex-wrap justify-center gap-2 mb-2">
				{aiTools.map((tool) => (
					<span class={`inline-flex items-center gap-2 rounded-full border bg-gradient-to-r px-3 py-1.5 text-xs font-medium text-white ${tool.color} ${tool.border}`}>
						<span class={`inline-flex h-5 w-5 shrink-0 items-center justify-center rounded ${tool.iconBg ?? ""}`}>
							<BrandIcon icon={tool.icon} src={tool.logoSrc} label={tool.name} class="h-3.5 w-3.5" />
						</span>
						{tool.name}
					</span>
				))}
			</div>

			<div class="funnel-connector funnel-connector--vertical mx-auto h-14 w-8" aria-hidden="true">
				<div class="funnel-connector__track funnel-connector__track--vertical"></div>
				<span class="funnel-dot funnel-dot--vertical funnel-dot--1"></span>
				<span class="funnel-dot funnel-dot--vertical funnel-dot--2"></span>
			</div>

			<div class="mx-auto max-w-xs rounded-2xl border border-amber-500/25 bg-gradient-to-br from-amber-500/10 to-orange-500/5 px-4 py-3 text-center">
				<p class="text-sm font-semibold text-white">HTML + CSS</p>
			</div>

			<div class="funnel-connector funnel-connector--vertical mx-auto h-14 w-8" aria-hidden="true">
				<div class="funnel-connector__track funnel-connector__track--vertical"></div>
				<span class="funnel-dot funnel-dot--vertical funnel-dot--1"></span>
				<span class="funnel-dot funnel-dot--vertical funnel-dot--2"></span>
			</div>

			<div class="mx-auto max-w-xs rounded-2xl border border-blue-500/35 bg-gradient-to-br from-blue-500/15 to-violet-500/10 px-4 py-3 text-center funnel-destination">
				<div class="mx-auto mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-white p-1">
					<BrandIcon icon={siWordpress} label="WordPress" class="h-full w-full" fill="#000000" />
				</div>
				<p class="text-sm font-semibold text-white">WordPress theme</p>
				<p class="text-xs text-blue-200/80 mt-0.5">Templates · Blocks · Handover</p>
			</div>
		</div>
	</div>
</section>

<style>
	.funnel-connector {
		position: relative;
		flex-shrink: 0;
	}

	.funnel-connector--horizontal {
		height: 2rem;
	}

	.funnel-connector--vertical {
		height: 3.5rem;
		width: 2rem;
	}

	.funnel-connector__track {
		position: absolute;
		top: 50%;
		left: 0;
		right: 1.25rem;
		height: 2px;
		transform: translateY(-50%);
		background: repeating-linear-gradient(
			90deg,
			rgb(139 92 246 / 0.15) 0,
			rgb(139 92 246 / 0.15) 6px,
			rgb(96 165 250 / 0.5) 6px,
			rgb(96 165 250 / 0.5) 12px
		);
		background-size: 24px 2px;
		animation: funnel-march 1s linear infinite;
		border-radius: 9999px;
	}

	.funnel-connector__track--vertical {
		top: 0;
		bottom: 0.5rem;
		left: 50%;
		right: auto;
		width: 2px;
		height: auto;
		transform: translateX(-50%);
		background: repeating-linear-gradient(
			180deg,
			rgb(139 92 246 / 0.15) 0,
			rgb(139 92 246 / 0.15) 6px,
			rgb(96 165 250 / 0.5) 6px,
			rgb(96 165 250 / 0.5) 12px
		);
		background-size: 2px 24px;
		animation: funnel-march-vertical 1s linear infinite;
	}

	.funnel-arrow {
		position: absolute;
		right: 0;
		top: 50%;
		width: 1.25rem;
		height: 1.25rem;
		transform: translateY(-50%);
		color: rgb(167 139 250);
	}

	.funnel-dot {
		position: absolute;
		top: 50%;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 9999px;
		background: rgb(196 181 253);
		box-shadow: 0 0 10px rgb(139 92 246 / 0.8);
		transform: translateY(-50%);
		animation: funnel-flow-x 2.4s ease-in-out infinite;
	}

	.funnel-dot--vertical {
		left: 50%;
		top: 0;
		transform: translateX(-50%);
		animation-name: funnel-flow-y;
	}

	.funnel-dot--1 { animation-delay: 0s; }
	.funnel-dot--2 { animation-delay: 0.8s; }
	.funnel-dot--3 { animation-delay: 1.6s; }

	.funnel-destination {
		animation: funnel-glow 3s ease-in-out infinite;
	}

	@keyframes funnel-march {
		from { background-position: 0 0; }
		to { background-position: 24px 0; }
	}

	@keyframes funnel-march-vertical {
		from { background-position: 0 0; }
		to { background-position: 0 24px; }
	}

	@keyframes funnel-flow-x {
		0% { left: 0; opacity: 0; }
		8% { opacity: 1; }
		92% { opacity: 1; }
		100% { left: calc(100% - 1.25rem); opacity: 0; }
	}

	@keyframes funnel-flow-y {
		0% { top: 0; opacity: 0; }
		8% { opacity: 1; }
		92% { opacity: 1; }
		100% { top: calc(100% - 0.5rem); opacity: 0; }
	}

	@keyframes funnel-glow {
		0%, 100% { box-shadow: 0 0 0 rgb(59 130 246 / 0); }
		50% { box-shadow: 0 0 24px rgb(59 130 246 / 0.15); }
	}

	@media (prefers-reduced-motion: reduce) {
		.funnel-connector__track,
		.funnel-dot,
		.funnel-destination {
			animation: none;
		}
	}
</style>
