---
import type { ImageMetadata } from "astro";

interface Props {
	title: string;
	subtitle: string;
	image: ImageMetadata;
	url: string;
	delay: string;
	compact?: boolean;
}

const { title, subtitle, image, url, delay, compact = false } = Astro.props;
---

<div
	class={`project-item group animate-item ${delay}`}
	data-image={image.src}
	data-url={url}
>
	{
		compact ? (
			<div class="flex items-center justify-between gap-2 py-2.5 px-3 sm:gap-3 sm:py-4 sm:px-6 bg-white/60 backdrop-blur-sm border border-neutral-200/40 rounded-xl hover:bg-white hover:shadow-lg transition-all duration-300 cursor-pointer">
				<div class="flex items-center gap-2.5 sm:gap-3 flex-1 min-w-0">
					<img
						src={image.src}
						alt=""
						width={64}
						height={48}
						loading="lazy"
						class="project-thumb lg:hidden shrink-0 w-16 h-12 rounded-md object-cover border border-neutral-200/80"
					/>
					<div class="min-w-0 text-left">
						<h4 class="text-base sm:text-lg font-heading font-semibold text-neutral-900 group-hover:text-teal-600 transition-colors duration-300 truncate">{title}</h4>
						<p class="text-neutral-500 text-xs truncate">{subtitle}</p>
					</div>
				</div>
				<svg class="w-4 h-4 shrink-0 text-neutral-400 group-hover:text-teal-600 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
				</svg>
			</div>
		) : (
			<div class="flex items-center justify-between gap-2 py-2.5 px-3 sm:gap-3 sm:py-6 sm:px-8 bg-white/80 backdrop-blur-sm border border-neutral-200/50 rounded-2xl hover:bg-white hover:shadow-xl hover:shadow-teal-500/10 transition-all duration-500 cursor-pointer">
				<div class="flex items-center gap-2.5 sm:gap-4 flex-1 min-w-0">
					<img
						src={image.src}
						alt=""
						width={80}
						height={56}
						loading="lazy"
						class="project-thumb lg:hidden shrink-0 w-20 h-14 sm:w-20 sm:h-14 rounded-lg object-cover border border-neutral-200/80"
					/>
					<div class="min-w-0">
						<h3 class="text-lg sm:text-xl lg:text-2xl xl:text-3xl font-heading font-bold text-neutral-900 group-hover:text-teal-600 transition-colors duration-300 truncate sm:whitespace-normal">{title}</h3>
						<p class="text-neutral-500 text-xs sm:text-sm mt-1 line-clamp-2 sm:line-clamp-none">{subtitle}</p>
					</div>
				</div>
				<div class="flex items-center gap-4 shrink-0">
					<span class="text-sm text-neutral-400 opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden sm:block">View Project</span>
					<svg class="w-5 h-5 sm:w-6 sm:h-6 text-neutral-400 group-hover:text-teal-600 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
					</svg>
				</div>
			</div>
		)
	}
</div>
