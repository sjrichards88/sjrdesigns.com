---
import Layout from "@/layouts/Layout.astro";
import AiWordPressFunnel from "@/components/sections/AiWordPressFunnel.astro";
import { contactHref } from "@/lib/contactServices";

export const prerender = true;

const aiContactUrl = contactHref("ai-html-to-wordpress");

const pageUrl = "https://sjrdesigns.com/ai-html-to-wordpress-theme/";

const pageKeywords =
	"AI HTML to WordPress, convert AI website to WordPress, AI-generated HTML theme conversion, WordPress theme from ChatGPT, v0 to WordPress";

const faqs = [
	{
		question: "Can you convert any AI-generated HTML into a WordPress theme?",
		answer:
			"In most cases, yes. I work from HTML and CSS produced by tools like ChatGPT, Claude, v0, Bolt, Lovable, Framer exports, or other generators, clean up the markup, split it into proper WordPress templates, and wire everything into the CMS. Very experimental layouts may need small design adjustments for WordPress constraints.",
	},
	{
		question: "Will my site look the same as the AI-generated preview?",
		answer:
			"The goal is a pixel-faithful or near-faithful match to your approved static design, implemented with valid theme structure, responsive behaviour, and WordPress best practices. If something cannot map cleanly to blocks or templates, I will flag it before build.",
	},
	{
		question: "Do I need my own WordPress hosting?",
		answer:
			"You can deploy the finished theme to hosting you already use. If you prefer, we can pair the one-off build with my optional monthly packages that include hosting, SSL, and maintenance - but you are not required to use them.",
	},
	{
		question: "Is this only available on a monthly subscription?",
		answer:
			"No. The conversion is usually quoted as a one-off project with fixed scope and price. Monthly packages are a separate option if you want ongoing hosting and support after handover.",
	},
	{
		question: "How long does an AI HTML to WordPress conversion take?",
		answer:
			"Typical marketing sites take roughly one to three weeks depending on page count, dynamic features, forms, and ecommerce hooks. I will give you a fixed scope and timeline after reviewing your HTML and requirements.",
	},
];

const faqEntities = faqs.map(({ question, answer }) => ({
	"@type": "Question",
	name: question,
	acceptedAnswer: {
		"@type": "Answer",
		text: answer,
	},
}));

const pageSchema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Service",
			name: "AI HTML to WordPress theme conversion",
			description:
				"One-off conversion of AI-generated static HTML and CSS into a production-ready, editable WordPress theme (templates, theme.json where appropriate, CMS-friendly structure). Optional ongoing hosting and care available separately.",
			serviceType: "WordPress theme development",
			url: pageUrl,
			provider: {
				"@type": "Person",
				name: "Simon Richards",
				url: "https://sjrdesigns.com",
			},
			areaServed: {
				"@type": "Country",
				name: "United Kingdom",
			},
			offers: {
				"@type": "Offer",
				priceCurrency: "GBP",
				priceSpecification: {
					"@type": "PriceSpecification",
					minPrice: "800",
					maxPrice: "1200",
					priceCurrency: "GBP",
					description: "Starting range for straightforward marketing site conversions",
				},
			},
		},
		{
			"@type": "FAQPage",
			mainEntity: faqEntities,
		},
	],
};

const breadcrumbs = [
	{ name: "Home", url: "https://sjrdesigns.com" },
	{ name: "AI HTML to WordPress theme", url: pageUrl },
];

const whatYouGet = [
	{
		title: "Production theme structure",
		description:
			"Clean theme folder, sensible template split, navigation menus, widget areas or block theme configuration as appropriate, and standards-friendly markup.",
		gradient: "from-violet-500 to-indigo-600",
		border: "border-violet-500/20",
		shadow: "hover:shadow-violet-500/15",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />`,
	},
	{
		title: "Editable content",
		description:
			"Content that should change often lives in the block editor, custom fields (ACF or native where it fits), or patterns - not buried in raw HTML files.",
		gradient: "from-emerald-500 to-teal-600",
		border: "border-emerald-500/20",
		shadow: "hover:shadow-emerald-500/15",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />`,
	},
	{
		title: "Performance and SEO baseline",
		description:
			"Assets enqueued correctly, lazy loading where it helps, semantic headings, and a foundation that works with your SEO plugin of choice.",
		gradient: "from-amber-500 to-orange-600",
		border: "border-amber-500/20",
		shadow: "hover:shadow-amber-500/15",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
	},
	{
		title: "Handover you can own",
		description:
			"Documentation for how templates map to pages, how to add sections, and optional training so you or your team can iterate without starting from zero.",
		gradient: "from-blue-500 to-cyan-600",
		border: "border-blue-500/20",
		shadow: "hover:shadow-blue-500/15",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
	},
];
---

<Layout
	title="AI HTML to WordPress Theme Conversion | Simon Richards"
	description="Turn AI-generated HTML into a real WordPress theme from £800. One-off projects with proper templates, editable content, and SEO-ready handover. UK developer Simon Richards - optional monthly care if you want it."
	schema={pageSchema}
	breadcrumbs={breadcrumbs}
	keywords={pageKeywords}
	includeGeoMeta={false}
>
	<main class="min-h-screen overflow-x-clip bg-gradient-to-br from-neutral-900 via-neutral-800 to-neutral-900">
		<section class="relative overflow-hidden pt-32 sm:pt-40 pb-10 sm:pb-14 px-4 sm:px-6 lg:px-8">
			<div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"></div>
			<div class="absolute top-0 right-1/4 w-96 h-96 bg-violet-500/10 rounded-full blur-3xl"></div>
			<div class="absolute bottom-0 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>

			<div class="relative max-w-5xl mx-auto text-center">
				<div class="inline-flex items-center gap-2 px-4 py-2 bg-violet-500/10 border border-violet-500/25 rounded-full backdrop-blur-sm mb-6">
					<span class="text-violet-300 text-sm font-medium">WordPress Development · AI-to-CMS Conversion</span>
				</div>
				<h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
					Turn AI-generated HTML into a <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-blue-400">usable WordPress theme</span>
				</h1>
				<p class="text-lg sm:text-xl text-neutral-300 mx-auto leading-relaxed">
					Static pages from ChatGPT, Claude, v0, Framer, or other tools are a fast way to explore design - but they are not a CMS. I convert your AI-built or exported HTML and CSS into a real WordPress theme you can edit, extend, and run in production. Most projects are a <span class="text-white font-medium">one-off build and handover</span> - monthly care is optional, not required.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
					<a
						href={aiContactUrl}
						class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white bg-gradient-to-r from-violet-600 to-blue-600 hover:from-violet-500 hover:to-blue-500 shadow-lg shadow-violet-500/25 transition-all duration-300"
					>
						Send me your HTML
					</a>
					<a
						href="/pricing/"
						class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white border border-white/20 hover:bg-white/5 transition-all duration-300"
					>
						Optional monthly packages
					</a>
				</div>
			</div>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Why this service exists</h2>
			<p class="text-neutral-300 leading-relaxed mb-4">
				AI coding assistants are excellent at producing landing-page HTML in minutes. What they do not give you is a maintainable WordPress theme: template hierarchy (<code class="text-violet-300 text-sm break-all">header.php</code>, <code class="text-violet-300 text-sm break-all">front-page.php</code>, patterns, blocks), enqueueing of scripts and styles, security-conscious output, editable fields for your team, and a path to future features.
			</p>
			<p class="text-neutral-300 leading-relaxed">
				This offering closes that gap. You keep the creative direction from your AI prototype; I implement it as a proper WordPress theme so you are not stuck pasting HTML into a single page or relying on fragile page-builder imports.
			</p>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-8 text-center">What you get</h2>
			<div class="grid sm:grid-cols-2 gap-6">
				{whatYouGet.map((item) => (
					<div class={`group bg-white/5 border ${item.border} rounded-2xl p-6 hover:bg-white/[0.07] hover:-translate-y-0.5 transition-all duration-300 hover:shadow-lg ${item.shadow}`}>
						<div class={`w-12 h-12 bg-gradient-to-br ${item.gradient} rounded-xl flex items-center justify-center mb-4 group-hover:scale-105 transition-transform duration-300 shadow-lg`}>
							<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" set:html={item.icon} />
						</div>
						<h3 class="text-lg font-semibold text-white mb-2">{item.title}</h3>
						<p class="text-neutral-300 text-sm leading-relaxed">{item.description}</p>
					</div>
				))}
			</div>
			<p class="text-neutral-400 text-sm text-center mt-8 leading-relaxed">
				See the quality bar in my <a href="/#work" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">portfolio work</a> - including CMS builds for major brands and independent sites like <a href="https://bouquetsandbows.com/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2" rel="noopener noreferrer">Bouquets &amp; Bows</a>.
			</p>
		</section>

		<AiWordPressFunnel />

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Why not just use a page builder?</h2>
			<p class="text-neutral-300 leading-relaxed">
				Page builders like Elementor or Divi are valid tools, but they often bloat load times, create vendor lock-in, and do not always handle custom layouts cleanly. A proper theme gives you a lighter, more maintainable foundation - especially if your AI-generated layout is bespoke and you want to own the code after handover.
			</p>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<div class="bg-white/5 border border-white/10 rounded-2xl p-6 sm:p-8">
				<p class="text-violet-300 text-sm font-medium mb-3">Recent work in this space</p>
				<p class="text-neutral-300 leading-relaxed italic">
					Recent projects include converting a v0 prototype for a German SaaS startup and rebuilding a London events agency site from AI-generated HTML - both delivered as proper WordPress themes with editable content areas and a clean handover.
				</p>
				<p class="text-neutral-400 text-sm mt-4">
					- Simon Richards, senior WordPress &amp; full-stack developer (8+ years, Disney, BBC, Barclays)
				</p>
			</div>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Pricing</h2>
			<p class="text-neutral-300 leading-relaxed mb-4">
				This work is normally quoted as a <span class="text-white font-medium">one-off project</span> - clear scope, fixed price, and full handover of the theme. You are not tied to a subscription to get the conversion done.
			</p>
			<p class="text-neutral-300 leading-relaxed mb-4">
				Projects typically start from <span class="text-white font-semibold">£800-£1,200</span> for a straightforward marketing site conversion and scale with page count, dynamic features, and complexity.
			</p>
			<p class="text-neutral-300 leading-relaxed mb-8">
				If you want hosting, SSL, and ongoing updates handled for you afterwards, <a href="/pricing/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">monthly packages</a> are available as a separate choice - many clients take the one-off build only and run the site themselves.
			</p>
			<a
				href={aiContactUrl}
				class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white bg-gradient-to-r from-violet-600 to-blue-600 hover:from-violet-500 hover:to-blue-500 transition-all duration-300"
			>
				Tell me about your project
			</a>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-6">How the process works</h2>
			<ol class="space-y-5 text-neutral-300 list-decimal list-inside marker:text-violet-400">
				<li>
					<span class="font-semibold text-white">Review</span> - We align on your AI-generated HTML/CSS (however you already have it - export, repo, or ZIP), plus brand assets and hosting context, once we have spoken.
				</li>
				<li>
					<span class="font-semibold text-white">Plan</span> - I map pages to templates, identify dynamic areas (blog, forms, team members, case studies), and confirm block vs classic theme approach.
				</li>
				<li>
					<span class="font-semibold text-white">Build</span> - Theme development, content migration strategy, and staging deployment for your review.
				</li>
				<li>
					<span class="font-semibold text-white">Launch</span> - Production cutover, redirects if needed, and handover. If you want hosting and updates bundled afterwards, <a href="/pricing/" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">monthly packages</a> are optional - not part of the core one-off quote unless you choose them.
				</li>
			</ol>
			<p class="text-neutral-400 text-sm mt-8 leading-relaxed">
				Want to see how I work on larger builds? Browse <a href="/#work" class="text-blue-400 hover:text-blue-300 underline underline-offset-2">featured work on the homepage</a>.
			</p>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-16 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Is this right for you?</h2>
			<p class="text-neutral-300 leading-relaxed mb-4">
				Founders, marketers, and agencies who used AI to speed up design exploration and now need a real CMS. It is especially useful when you already like the look of your static HTML but do not have time to learn the WordPress theme layer yourself.
			</p>
			<p class="text-neutral-300 leading-relaxed">
				If you are unsure whether your HTML is ready or how a one-off quote might look, <a href={aiContactUrl} class="text-blue-400 hover:text-blue-300 underline underline-offset-2">tell me about your project</a> - I will reply honestly about what is feasible and what a fixed scope would look like.
			</p>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-20 max-w-5xl mx-auto">
			<h2 class="text-2xl sm:text-3xl font-bold text-white mb-8">Frequently asked questions</h2>
			<div class="space-y-3">
				{faqs.map((faq, index) => (
					<details class="faq-item group rounded-2xl border border-white/10 bg-white/5 overflow-hidden" open={index === 0}>
						<summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-left font-semibold text-white hover:bg-white/[0.04] transition-colors [&::-webkit-details-marker]:hidden">
							<span>{faq.question}</span>
							<svg class="faq-chevron h-5 w-5 shrink-0 text-violet-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</summary>
						<div class="px-5 pb-5 pt-0">
							<p class="text-neutral-300 leading-relaxed border-t border-white/10 pt-4">
								{faq.answer}
							</p>
						</div>
					</details>
				))}
			</div>
		</section>

		<section class="relative px-4 sm:px-6 lg:px-8 pb-24 max-w-5xl mx-auto text-center">
			<div class="bg-gradient-to-br from-violet-500/10 to-blue-500/10 border border-white/10 rounded-2xl p-10">
				<h2 class="text-2xl font-bold text-white mb-3">Ready to make your AI layout real?</h2>
				<p class="text-neutral-300 mb-8 max-w-4xl mx-auto">
					Send a short note about your project and goals. I will reply with next steps, what I need to see, and a realistic one-off scope - usually within one working day.
				</p>
				<a
					href={aiContactUrl}
					class="inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-white bg-gradient-to-r from-violet-600 to-blue-600 hover:from-violet-500 hover:to-blue-500 transition-all duration-300"
				>
					Start with a free scope call
				</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	html {
		scroll-behavior: smooth;
	}

	.faq-item[open] {
		border-color: rgb(139 92 246 / 0.35);
		background-color: rgb(255 255 255 / 0.07);
	}

	.faq-item[open] .faq-chevron {
		transform: rotate(180deg);
	}
</style>
